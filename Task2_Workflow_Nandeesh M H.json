        {
            "parameters": {
                "jsCode": "let message = \"🚀 Crypto Market Digest\\n\\n\";\n\nfor (const item of items) {\n\n  const coin = item.json;\n\n  message += `💰 ${coin.name}\\n`;\n  message += `📈 Change: ${coin.market_data.price_change_percentage_24h}%\\n`;\n  message += `💵 Price: $${coin.market_data.current_price.usd}\\n\\n`;\n}\n\nreturn [\n  {\n    json: {\n      content: message\n    }\n  }\n];"
            },
