        {
            "parameters": {
                "jsCode": "const coins = items.map(item => item.json);\n\ncoins.sort((a, b) => b.market_cap - a.market_cap);\n\nconst top5 = coins.slice(0, 5);\n\nreturn top5.map(coin => {\n  return {\n    json: {\n      name: coin.name,\n      symbol: coin.symbol,\n      price: coin.current_price,\n      market_cap: coin.market_cap,\n      change: coin.price_change_percentage_24h,\n      id: coin.id\n    }\n  };\n});"
            },
